generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pgcrypto]
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String   @db.VarChar(255)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Soft-delete for GDPR — row purged by scheduled job 30d later
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  // ── Compliance (UK GDPR / EU GDPR Art 9 + ICO Children's Code) ──
  // Year-only (no exact DOB stored — minimises PII while still enforcing 13+).
  birthYear        Int?      @map("birth_year") @db.SmallInt
  // Children's Code mode: true when user self-identifies as 13-17.
  // Server enforces local-only AI, reduced telemetry, safer defaults.
  childMode        Boolean   @default(false) @map("child_mode")
  // Explicit Art 9(2)(a) consent to process special-category (mental health) data.
  consentedAt      DateTime? @map("consented_at") @db.Timestamptz(6)
  consentVersion   String?   @map("consent_version") @db.VarChar(16)
  // Retention choice: `forever` | `1y` | `90d`. NULL = not yet chosen.
  retentionPolicy  String?   @map("retention_policy") @db.VarChar(16)
  // Region hint for data-residency (ISO-3166, e.g. "GB", "DE", "US").
  region           String?   @db.VarChar(2)
  // Locale hint (e.g. "en-GB"). Used to pick SOS default + copy.
  locale           String?   @db.VarChar(10)

  // Relations
  conversations   Conversation[]
  journalEntries  JournalEntry[]
  moodLogs        MoodLog[]
  wellnessProfile WellnessProfile?
  userState       UserState?
  memories        Memory[]
  safetyPlan      SafetyPlan?
  auditLogs       AuditLog[]
  reminders       Reminder[]
  digestCaches    DigestCache[]
  gratitude       GratitudeEntry[]
  futureLetters   FutureLetter[]
  clinicalResults ClinicalResult[]
  affirmations    AffirmationCache[]
  consentLogs     ConsentLog[]

  @@index([deletedAt])
  @@map("users")
}

// ============================================================================
// CONSENT LOG — immutable record of consent events (UK GDPR accountability)
// ============================================================================
// Every grant / withdraw / retention change is appended here and never mutated.
// Used to prove lawful basis on SAR or ICO audit.

model ConsentLog {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // grant | withdraw | retention_change | age_confirm | child_mode_enabled
  event          String   @db.VarChar(32)
  // "v1", "v2" … version of the consent text the user accepted
  consentVersion String   @map("consent_version") @db.VarChar(16)
  // Retention choice at the moment of the event (for retention_change events)
  retention      String?  @db.VarChar(16)
  ipHash         String?  @map("ip_hash") @db.VarChar(64)
  userAgent      String?  @map("user_agent") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@map("consent_logs")
}

// ============================================================================
// WELLNESS PROFILE — AI-Generated from 6-Step Onboarding
// ============================================================================

model WellnessProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Raw 6-step dynamic answers
  energy          String   @db.VarChar(20)   // high | moderate | low
  concern         String   @db.VarChar(50)   // dynamic — varies by energy level
  context         String   @db.VarChar(50)   // dynamic — varies by energy + concern
  approach        String   @db.VarChar(50)   // dynamic — what they need
  supportStyle    String   @map("support_style") @db.VarChar(50) // how they want AI to communicate
  timeAvailable   String   @map("time_available") @db.VarChar(10) // 1 | 3 | 5 | 10

  // AI-generated profile (JSON)
  profile         Json     @db.JsonB // Full recommendation profile
  aiInsight       String   @map("ai_insight") @db.Text // AI-written personalized insight
  
  // New Adaptive Tree Data
  adaptiveAnswers Json?    @map("adaptive_answers") @db.JsonB
  
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("wellness_profiles")
}

// ============================================================================
// ONBOARDING ASSESSMENT (3-Question Branching Tree — v2.2)
// ============================================================================

model AssessmentQuestion {
  id             String  @id @default(uuid()) @db.Uuid
  stepNumber     Int     @map("step_number") @db.SmallInt
  routeGroup     String  @map("route_group") @db.VarChar(20) // shared, overwhelmed, anxious, frustrated, sad, pressure
  questionText   String  @map("question_text") @db.Text

  // Option A
  answerAText    String  @map("answer_a_text") @db.Text
  meaningA       String  @map("meaning_a") @db.VarChar(100)
  nextRouteA     String  @map("next_route_a") @db.VarChar(50)
  scoreDimA      String  @map("score_dim_a") @db.VarChar(20)
  scoreValA      Int     @map("score_val_a") @db.SmallInt
  safetyFlagA    String  @map("safety_flag_a") @default("none") @db.VarChar(30)
  emotionSignalsA Json?  @map("emotion_signals_a") @db.JsonB

  // Option B
  answerBText    String  @map("answer_b_text") @db.Text
  meaningB       String  @map("meaning_b") @db.VarChar(100)
  nextRouteB     String  @map("next_route_b") @db.VarChar(50)
  scoreDimB      String  @map("score_dim_b") @db.VarChar(20)
  scoreValB      Int     @map("score_val_b") @db.SmallInt
  safetyFlagB    String  @map("safety_flag_b") @default("none") @db.VarChar(30)
  emotionSignalsB Json?  @map("emotion_signals_b") @db.JsonB

  // Option C
  answerCText    String  @map("answer_c_text") @db.Text
  meaningC       String  @map("meaning_c") @db.VarChar(100)
  nextRouteC     String  @map("next_route_c") @db.VarChar(50)
  scoreDimC      String  @map("score_dim_c") @db.VarChar(20)
  scoreValC      Int     @map("score_val_c") @db.SmallInt
  safetyFlagC    String  @map("safety_flag_c") @default("none") @db.VarChar(30)
  emotionSignalsC Json?  @map("emotion_signals_c") @db.JsonB

  // Option D (optional — used by Q2/Q3 branches)
  answerDText    String?  @map("answer_d_text") @db.Text
  meaningD       String?  @map("meaning_d") @db.VarChar(100)
  nextRouteD     String?  @map("next_route_d") @db.VarChar(50)
  scoreDimD      String?  @map("score_dim_d") @db.VarChar(20)
  scoreValD      Int?     @map("score_val_d") @db.SmallInt
  safetyFlagD    String?  @map("safety_flag_d") @db.VarChar(30)
  emotionSignalsD Json?   @map("emotion_signals_d") @db.JsonB

  // Option E (optional — used by Q1 only)
  answerEText    String?  @map("answer_e_text") @db.Text
  meaningE       String?  @map("meaning_e") @db.VarChar(100)
  nextRouteE     String?  @map("next_route_e") @db.VarChar(50)
  scoreDimE      String?  @map("score_dim_e") @db.VarChar(20)
  scoreValE      Int?     @map("score_val_e") @db.SmallInt
  safetyFlagE    String?  @map("safety_flag_e") @db.VarChar(30)
  emotionSignalsE Json?   @map("emotion_signals_e") @db.JsonB

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([stepNumber, routeGroup])
  @@map("assessment_questions")
}

// ============================================================================
// CONVERSATIONS & MESSAGES — The Core AI Chat
// ============================================================================

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  messages Message[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       @db.VarChar(20) // 'user' | 'assistant' | 'system'
  content        String       @db.Text
  // Semantic embedding (only stored for 'user' messages to feed RAG)
  embedding      Unsupported("vector(1536)")?
  embeddingModel String?      @map("embedding_model") @db.VarChar(50)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}

// ============================================================================
// JOURNAL — Encrypted Personal Entries
// ============================================================================

model JournalEntry {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Plaintext fallback (kept for legacy rows + when encryption disabled)
  content        String   @db.Text
  // AES-256-GCM ciphertext (iv|tag|ct, base64). When set, `content` is a summary placeholder.
  cipherText     String?  @map("cipher_text") @db.Text
  mood           String?  @db.VarChar(50)
  // Semantic embedding (1536-dim, OpenAI text-embedding-3-small size; nullable until backfilled)
  embedding      Unsupported("vector(1536)")?
  embeddingModel String?  @map("embedding_model") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([createdAt])
  @@map("journal_entries")
}

// ============================================================================
// MOOD LOGS — Track Emotional State
// ============================================================================

model MoodLog {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood           String   @db.VarChar(50)
  intensity      Int      @db.SmallInt // 1-10
  note           String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([createdAt])
  @@map("mood_logs")
}

// ============================================================================
// AI ENGINE — Living User State (evolves each session)
// ============================================================================

model UserState {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  currentArchetype     String   @map("current_archetype") @db.VarChar(100)
  emotionalTrajectory  Json     @map("emotional_trajectory") @db.JsonB   // { direction, last7: number[], trend }
  sessionCount         Int      @default(0) @map("session_count")
  lastCrisisFlag       DateTime? @map("last_crisis_flag") @db.Timestamptz(6)
  copingStrength       Float    @default(0.5) @map("coping_strength")    // 0–1
  engagementPattern    Json     @default("{}") @map("engagement_pattern") @db.JsonB  // { toolsUsed, toolsSkipped, favorites }
  contextWindow        Json     @default("[]") @map("context_window") @db.JsonB      // last 5 interaction summaries

  computedAt           DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("user_states")
}

// ============================================================================
// TOOL USAGE — Track which wellness tools users complete/skip
// ============================================================================

model ToolUsage {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  toolId     String   @map("tool_id") @db.VarChar(50)    // e.g. 'box_breathing'
  action     String   @db.VarChar(20)                     // 'started' | 'completed' | 'skipped'
  duration   Int?     @db.SmallInt                        // seconds spent (if completed)
  moodBefore Int?     @map("mood_before") @db.SmallInt    // 1-10 mood before
  moodAfter  Int?     @map("mood_after") @db.SmallInt     // 1-10 mood after
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([toolId])
  @@index([createdAt])
  @@map("tool_usage")
}

// ============================================================================
// MEMORY — User-blessed long-term memories surfaced to AI chat via RAG
// ============================================================================

model Memory {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // What the user (or AI with consent) asked us to remember
  content        String   @db.Text
  // Category helps the prompt ("context", "preference", "goal", "boundary", "relationship", "event")
  kind           String   @default("context") @db.VarChar(20)
  // 0.0-1.0 — how confident we are this is still relevant (decays over time)
  salience       Float    @default(1.0)
  // Semantic embedding for similarity retrieval
  embedding      Unsupported("vector(1536)")?
  embeddingModel String?  @map("embedding_model") @db.VarChar(50)
  // Source that produced this memory: 'user' (explicit save) or 'ai' (inferred with consent)
  source         String   @default("user") @db.VarChar(20)
  lastUsedAt     DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([createdAt])
  @@map("memories")
}

// ============================================================================
// SAFETY PLAN — User's personal crisis plan (structured, private)
// ============================================================================

model SafetyPlan {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  warningSigns   Json     @default("[]") @map("warning_signs") @db.JsonB // string[]
  copingStrategies Json   @default("[]") @map("coping_strategies") @db.JsonB // string[]
  reasonsToLive  Json     @default("[]") @map("reasons_to_live") @db.JsonB // string[]
  supportPeople  Json     @default("[]") @map("support_people") @db.JsonB // {name, phone, relationship}[]
  professionals  Json     @default("[]") @map("professionals") @db.JsonB // {name, phone, role}[]
  safeSpaces     Json     @default("[]") @map("safe_spaces") @db.JsonB // string[]
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("safety_plans")
}

// ============================================================================
// AUDIT LOG — every mutating user-initiated action (for privacy/export)
// ============================================================================

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  // SetNull (not Cascade) so the audit trail survives an Art 17 erasure —
  // ICO accountability requires we can prove the erasure happened.
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   @db.VarChar(64)   // e.g. 'journal.create'
  resource  String?  @db.VarChar(64)   // e.g. 'journal:<uuid>'
  ipHash    String?  @map("ip_hash") @db.VarChar(64)
  meta      Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ============================================================================
// REMINDER — gentle scheduled nudges ("check in in 2 hours", "journal tonight")
// ============================================================================

model Reminder {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   @db.VarChar(32)   // 'check_in', 'journal', 'tool', 'custom'
  message   String   @db.Text
  dueAt     DateTime @map("due_at") @db.Timestamptz(6)
  status    String   @default("pending") @db.VarChar(16) // pending | delivered | canceled
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, status])
  @@index([dueAt])
  @@map("reminders")
}

// ============================================================================
// DIGEST CACHE — generated weekly/daily AI digests, one per period
// ============================================================================

model DigestCache {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period    String   @db.VarChar(16)   // e.g. 'weekly', 'daily'
  periodKey String   @map("period_key") @db.VarChar(20)   // e.g. '2026-W17'
  payload   Json     @db.JsonB        // { summary, highlights, themes, nudge, moodTrend }
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, period, periodKey])
  @@index([userId, createdAt])
  @@map("digest_caches")
}


// ============================================================================
// GRATITUDE — daily gratitude entries + streak
// ============================================================================

model GratitudeEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Plaintext or summary placeholder — when cipherText is present, this is redacted
  content       String   @db.Text
  // AES-256-GCM ciphertext (iv|tag|ct, base64) — same pattern as JournalEntry
  cipherText    String?  @map("cipher_text") @db.Text
  dayKey        String   @map("day_key") @db.VarChar(10)   // 'YYYY-MM-DD' in UTC
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@index([userId, dayKey])
  @@map("gratitude_entries")
}

// ============================================================================
// FUTURE LETTER — "Letter to future you", encrypted, delivered on a date
// ============================================================================

model FutureLetter {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  cipherText String?  @map("cipher_text") @db.Text
  deliverAt  DateTime @map("deliver_at") @db.Timestamptz(6)
  delivered  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, deliverAt])
  @@map("future_letters")
}

// ============================================================================
// CLINICAL RESULT — validated questionnaires (PHQ-9, GAD-7)
// ============================================================================

model ClinicalResult {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  instrument String   @db.VarChar(16)   // 'phq9' | 'gad7'
  score      Int      @db.SmallInt
  severity   String   @db.VarChar(32)   // minimal | mild | moderate | moderately_severe | severe
  answers    Json     @db.JsonB        // number[]
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, instrument, createdAt])
  @@map("clinical_results")
}

// ============================================================================
// AFFIRMATION CACHE — one per user per day
// ============================================================================

model AffirmationCache {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayKey    String   @map("day_key") @db.VarChar(10)
  content   String   @db.Text
  tone      String   @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, dayKey])
  @@map("affirmation_caches")
}
